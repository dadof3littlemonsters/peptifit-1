diff --git a/app/styles/mobile.css b/app/styles/mobile.css
index 2095dd3..a5794df 100644
--- a/app/styles/mobile.css
+++ b/app/styles/mobile.css
@@ -1,55 +1,88 @@
-/* Dynamic viewport height - fixes Android Chrome address bar issue */
-:root {
-  --app-height: 100dvh;
+/* ═══════════════════════════════════════════════════════════════
+   PeptiFit Mobile — single source of truth for mobile layout
+   ═══════════════════════════════════════════════════════════════ */
+
+/* ── Viewport shell ───────────────────────────────────────────
+   Each page is a flex column that fills the screen:
+     header (flex-shrink-0)  →  main.page-content (flex-1, scrolls)  →  BottomNav (fixed)
+   We lock overflow on html/body/#__next so only .page-content scrolls.
+*/
+html {
+  font-size: 16px;
+  -webkit-text-size-adjust: 100%;
+  text-size-adjust: 100%;
 }
 
-html,
-body {
+html, body {
   height: 100%;
   overflow: hidden;
   overscroll-behavior: none;
-  -webkit-text-size-adjust: 100%;
-  text-size-adjust: 100%;
 }
 
-/* Ensure the Next.js root fills viewport */
 #__next {
   height: 100dvh;
-  height: 100vh;
+  height: 100vh; /* fallback for older browsers */
   display: flex;
   flex-direction: column;
   overflow: hidden;
 }
 
-/* Base font size bump for readability */
-html {
-  font-size: 16px;
+/* ── Scrollable content area ─────────────────────────────────
+   Every page's <main> should have class="page-content".
+   This is the ONLY element that scrolls on the page.
+*/
+.page-content {
+  flex: 1 1 0%;
+  overflow-y: auto;
+  overflow-x: hidden;
+  -webkit-overflow-scrolling: touch;
+  overscroll-behavior-y: contain;
 }
 
-/* Minimum tap target size */
+/* ── Tap targets ─────────────────────────────────────────────
+   Only apply 44px minimum to primary interactive elements.
+   Use a class for inline/small buttons that need to opt out.
+*/
 button,
-a,
-[role="button"] {
+[role="button"],
+input[type="submit"],
+input[type="button"] {
+  min-height: 44px;
+}
+
+/* Links only get the tap target when they're standalone nav/action items.
+   Inline text links (inside paragraphs, badges, etc.) should NOT be 44px. */
+a:not(.inline-link):not([class*="text-xs"]):not([class*="text-\[10px\]"]):not([class*="rounded-full"]) {
   min-height: 44px;
-  min-width: 44px;
 }
 
+/* Opt-out class for small inline buttons (sort toggles, badge buttons, etc.) */
+.btn-compact,
+.btn-compact a,
+.btn-compact button {
+  min-height: unset !important;
+  min-width: unset !important;
+}
+
+/* Prevent iOS zoom on input focus */
 input,
 select,
 textarea {
-  font-size: 16px;
+  font-size: 16px !important;
 }
 
-/* Safe area for bottom nav on Android */
+/* ── Bottom nav safe area ────────────────────────────────────
+   The BottomNav component handles its own safe-area via inline style,
+   but this class is available as a fallback.
+*/
 .bottom-nav {
   padding-bottom: max(12px, env(safe-area-inset-bottom));
 }
 
-/* Scrollable content area between fixed header and fixed nav */
-.page-content {
-  flex: 1;
-  overflow-y: auto;
-  overflow-x: hidden;
-  -webkit-overflow-scrolling: touch;
-  overscroll-behavior-y: contain;
+/* ── Standard bottom padding for page-content ────────────────
+   BottomNav is ~72px (56px content + 16px safe area).
+   Add this as default so no content is hidden behind the nav.
+*/
+.pb-nav {
+  padding-bottom: 5rem; /* 80px — safe clearance for bottom nav */
 }
