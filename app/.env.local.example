# ─────────────────────────────────────────────────────────────────────────────
# Local development environment template
#
# Copy this file to .env.local and fill in the values.
# .env.local is intentionally git-ignored — never commit real secrets.
#
# Usage:
#   cp .env.local.example .env.local
#   # then edit .env.local as needed
# ─────────────────────────────────────────────────────────────────────────────

# URL the browser uses to reach the backend API.
#
# Local development — start the backend first (cd ../backend && npm start),
# then point the frontend directly at it:
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Production / Docker — set this to the same-origin /api path so requests
# flow through Caddy's reverse proxy (see caddy/Caddyfile):
# NEXT_PUBLIC_API_URL=/api
