# ─── Stage 1: Install dependencies ──────────────────────────────────────────
FROM node:18-alpine AS deps

# libc6-compat is required by some native Node modules on Alpine
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy only the manifest files first so Docker layer caching re-uses the
# npm install layer whenever source files change but dependencies don't.
COPY package.json package-lock.json ./

RUN npm install


# ─── Stage 2: Build the application ──────────────────────────────────────────
FROM node:18-alpine AS builder

WORKDIR /app

# Bring in the installed node_modules from the deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy the rest of the source
COPY . .

# NEXT_PUBLIC_* variables are inlined at BUILD TIME by the Next.js compiler.
# They must be passed as Docker build ARGs — setting them only in
# docker-compose environment: is too late (that is runtime, not build time).
ARG NEXT_PUBLIC_API_URL=/api
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Disable Next.js telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build


# ─── Stage 3: Production runner ──────────────────────────────────────────────
FROM node:18-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-root user for security
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# Copy the public assets (served as-is)
COPY --from=builder /app/public ./public

# `output: 'standalone'` in next.config.js generates a minimal self-contained
# server under .next/standalone — only what is needed to run Next.js.
# Static assets are kept separate so they can be served directly by the CDN
# or reverse proxy without hitting Node.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static    ./.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# server.js is generated by `output: 'standalone'` and is the correct
# entrypoint — much lighter than running the full `next start` CLI.
CMD ["node", "server.js"]
